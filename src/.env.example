# --- Agentic Image Editor: environment ---
# v1 keeps it simple: ONE key. Everything routes through Vercel AI Gateway,
# so you can A/B Claude vs GPT vs Gemini by changing AGENT_MODEL — no code change.

# Vercel AI Gateway key (required). Create at: https://vercel.com → AI Gateway → API Keys
AI_GATEWAY_API_KEY=

# Optional: override the default vision model (provider/model string).
# Examples: anthropic/claude-sonnet-4-6  |  openai/gpt-5-mini  |  google/gemini-3-flash
AGENT_MODEL=anthropic/claude-sonnet-4-6

# Optional: max re-look iterations (default 30). Each iteration re-renders the config.
MAX_STEPS=30

# --- Develop engine (RawTherapee) ---
# Which DevelopEngine runner renders each pass.
#   sandbox = RawTherapee in a Vercel Sandbox microVM (production; needs RT_SNAPSHOT_ID + OIDC)
#   local   = local `rawtherapee-cli` binary (dev default)
#   sharp   = the legacy in-process Sharp fallback
# If `sandbox` is selected but its prerequisites are missing, the engine degrades
# to `local` (when RT_BIN resolves) else `sharp`, logging a one-line downgrade warning.
RT_EXECUTION=local

# Path to the local `rawtherapee-cli` for RT_EXECUTION=local (default `rawtherapee-cli` on PATH).
RT_BIN=rawtherapee-cli

# Snapshot id produced by `npx tsx src/scripts/build-rt-snapshot.ts` (one-time setup).
# Required for RT_EXECUTION=sandbox. See internal_docs/.../sandbox_setup.md.
RT_SNAPSHOT_ID=

# Vercel Sandbox auth. In dev, run `vercel link` then `vercel env pull` to fetch a
# VERCEL_OIDC_TOKEN (it lands in .env.local; TTL ~12h, re-pull when it expires).
# In Vercel deploys this token is injected automatically — no action needed.
VERCEL_OIDC_TOKEN=
