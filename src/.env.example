# --- Agentic Image Editor: environment ---
# v1 keeps it simple: ONE key. Everything routes through Vercel AI Gateway,
# so you can A/B Claude vs GPT vs Gemini by changing AGENT_MODEL — no code change.

# Vercel AI Gateway key (required). Create at: https://vercel.com → AI Gateway → API Keys
AI_GATEWAY_API_KEY=

# Optional: override the default vision model (provider/model string).
# Examples: anthropic/claude-sonnet-4-6  |  openai/gpt-5-mini  |  google/gemini-3-flash
AGENT_MODEL=anthropic/claude-sonnet-4-6

# Optional: max re-look iterations (default 30). Each iteration applies a batch of ops.
MAX_STEPS=30

# Optional: max operations per batch (default 6). Over-cap lines are dropped server-side.
MAX_OPS_PER_BATCH=6
